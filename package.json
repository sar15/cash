{
  "name": "cashflowiq",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node node_modules/next/dist/bin/next dev",
    "dev:webpack": "node node_modules/next/dist/bin/next dev --webpack",
    "build": "node node_modules/next/dist/bin/next build",
    "start": "node node_modules/next/dist/bin/next start",
    "lint": "node node_modules/eslint/bin/eslint.js .",
    "typecheck": "node node_modules/next/dist/bin/next typegen && node -e \"require('fs').readdirSync('.next/types').filter(f=>/ \\\\d+\\\\./.test(f)).forEach(f=>require('fs').unlinkSync('.next/types/'+f))\" && node node_modules/typescript/bin/tsc --noEmit",
    "test": "vitest run",
    "db:push": "drizzle-kit push",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "npx tsx scripts/apply-migrations.ts",
    "db:check": "npx tsx scripts/check-schema.mts",
    "db:seed-mappings": "npx tsx scripts/seed-standard-mappings.ts",
    "db:studio": "drizzle-kit studio",
    "seed": "node --loader tsx/esm src/lib/db/seed.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1025.0",
    "@base-ui/react": "^1.3.0",
    "@clerk/nextjs": "^7.0.11",
    "@hookform/resolvers": "^5.2.2",
    "@libsql/client": "^0.17.2",
    "@noble/ciphers": "^1.3.0",
    "@paralleldrive/cuid2": "^3.3.0",
    "@sentry/nextjs": "^10.20.0",
    "@serwist/next": "^9.5.7",
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/react-virtual": "^3.13.24",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.37.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "exceljs": "^4.4.0",
    "expr-eval": "^2.0.2",
    "html2canvas": "^1.4.1",
    "inngest": "^4.2.1",
    "jspdf": "^4.2.1",
    "lucide-react": "^1.7.0",
    "next": "^16.2.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.72.1",
    "recharts": "^3.8.1",
    "resend": "^6.10.0",
    "serwist": "^9.5.7",
    "shadcn": "^4.1.2",
    "svix": "^1.90.0",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "uploadthing": "^7.7.4",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "vitest": {
    "setupFiles": [
      "./vitest.setup.ts"
    ]
  },
  "overrides": {
    "effect": ">=3.20.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "^16.2.3",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.3"
  }
}
