# ============================================================
# CashFlowIQ — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git.
# ============================================================

# ── Clerk Auth (required) ──────────────────────────────────────────────────
# Get from: https://dashboard.clerk.com → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# Clerk Webhook (optional — enables welcome emails on signup)
# 1. Clerk Dashboard → Webhooks → Add Endpoint
# 2. URL: https://<your-domain>/api/webhooks/clerk
# 3. Subscribe to "user.created"
# 4. Copy the Signing Secret below
CLERK_WEBHOOK_SECRET=

# ── Database (required in production) ─────────────────────────────────────
# Get from: https://turso.tech → Create Database
# Dev fallback: file:local.db
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# ── Encryption (required) ─────────────────────────────────────────────────
# Generate: openssl rand -hex 32
ENCRYPTION_KEY=

# ── Email / Resend (optional) ──────────────────────────────────────────────
# Get from: https://resend.com → API Keys
# WARNING: onboarding@resend.dev is a shared test domain — spam-filtered in production.
# Verify your own domain at resend.com/domains before going live.
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@yourdomain.com

# ── Background Jobs / Inngest (optional) ──────────────────────────────────
# Get from: https://app.inngest.com → App → Keys
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# ── Rate Limiting / Upstash Redis (optional) ──────────────────────────────
# Get from: https://console.upstash.com → Create Database → REST API
# Without this: falls back to per-instance in-memory rate limiting
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── Error Monitoring / Sentry (optional) ──────────────────────────────────
# Get from: https://sentry.io → Create Project → Next.js → DSN
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# ── File Storage (Uploadthing) ─────────────────────────────────────────────
# Free tier: 2GB, no credit card required
# Get from: https://uploadthing.com → Create App → API Keys → Token
# Without this: uploads fall back to local filesystem (fine for dev, breaks on Vercel)
UPLOADTHING_TOKEN=

# ── File Storage (Cloudflare R2) — alternative, requires credit card ───────
# R2_ENDPOINT=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET_NAME=cashflowiq-uploads
